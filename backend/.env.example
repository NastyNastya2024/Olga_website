# ===========================================
# Локальная разработка (MinIO)
# Скопируйте в .env и запустите: docker-compose up -d minio
# ===========================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=olga-media
S3_REGION=us-east-1

PORT=5000

# ===========================================
# ЮKassa (оплата)
# ===========================================
# YOOKASSA_SHOP_ID=ваш_shop_id
# YOOKASSA_SECRET_KEY=ваш_секретный_ключ
# YOOKASSA_RECEIPT_EMAIL=ola_br@mail.ru
# YOOKASSA_RECEIPT_EMAIL_BACKUP=anastkomarova@yandex.ru  # Резервный email для чека

# ===========================================
# Деплой на Yandex Cloud (замените при деплое)
# ===========================================
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_ACCESS_KEY=ваш_access_key_из_консоли
# S3_SECRET_KEY=ваш_secret_key_из_консоли
# S3_BUCKET=olga-media
# S3_REGION=ru-central1
