# ===========================================
# Production: Yandex Object Storage (экосистема Yandex Cloud)
# Все медиа (видео, фото) хранятся в Yandex Cloud
# ===========================================
S3_ENDPOINT=https://storage.yandexcloud.net
S3_ACCESS_KEY=ваш_access_key_из_консоли_yandex
S3_SECRET_KEY=ваш_secret_key_из_консоли_yandex
S3_BUCKET=olga-website-media
S3_REGION=ru-central1

PORT=5000
NODE_ENV=production

# ===========================================
# Локальная разработка (MinIO) — только для dev
# docker-compose up -d minio
# ===========================================
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=olga-media
# S3_REGION=us-east-1

# ===========================================
# ЮKassa (оплата)
# ===========================================
# YOOKASSA_SHOP_ID=ваш_shop_id
# YOOKASSA_SECRET_KEY=ваш_секретный_ключ
# YOOKASSA_RECEIPT_EMAIL=ola_br@mail.ru
# YOOKASSA_RECEIPT_EMAIL_BACKUP=anastkomarova@yandex.ru
